# ── Hindsight Cloud ────────────────────────────────
# Sign up at: https://ui.hindsight.vectorize.io
# Use promo code: MEMHACK315 for $50 free credits
HINDSIGHT_API_URL=https://your-instance.hindsight.vectorize.io
HINDSIGHT_API_KEY=your_hindsight_api_key_here
